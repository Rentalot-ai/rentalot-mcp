{
  "name": "@rentalot/mcp-server",
  "version": "0.2.1",
  "description": "MCP server for the Rentalot API — manage rental properties, contacts, showings, and more from AI assistants",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rentalot-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:drift": "vitest run --config vitest.drift.config.ts",
    "test:e2e": "bun test/e2e.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rentalot-ai/rentalot-mcp.git"
  },
  "homepage": "https://github.com/Rentalot-ai/rentalot-mcp#readme",
  "bugs": {
    "url": "https://github.com/Rentalot-ai/rentalot-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "rentalot",
    "rental",
    "property-management",
    "ai-agent",
    "claude",
    "model-context-protocol"
  ]
}
